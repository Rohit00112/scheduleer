{
  "name": "schedule-hub",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,magenta,green \"pnpm --filter @schedule/api dev\" \"pnpm --filter @schedule/api worker:dev\" \"pnpm --filter @schedule/web dev\"",
    "dev:api": "pnpm --filter @schedule/api dev",
    "dev:web": "pnpm --filter @schedule/web dev",
    "dev:worker": "pnpm --filter @schedule/api worker:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @schedule/api prisma:generate",
    "db:migrate": "pnpm --filter @schedule/api prisma:migrate",
    "db:seed": "pnpm --filter @schedule/api prisma:seed"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  }
}
