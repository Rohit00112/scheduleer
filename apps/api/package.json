{
  "name": "@schedule/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "worker": "node dist/worker.js",
    "lint": "tsc -p tsconfig.build.json --noEmit",
