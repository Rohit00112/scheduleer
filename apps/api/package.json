    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.0.11",
    "@nestjs/websockets": "^11.0.11",
    "@prisma/client": "^6.4.1",
    "@schedule/parser": "workspace:*",
    "@schedule/shared-types": "workspace:*",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.5.0",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^7.0.3",
